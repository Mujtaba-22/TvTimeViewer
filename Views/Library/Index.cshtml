@model TvTimeViewer.Controllers.LibraryViewModel
@{
    ViewData["Title"] = "My Library";
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/Style/library.css" />
}

<h2 class="mb-3">My TV Library</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

<div id="updatesNotificationBar"></div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">Import GDPR ZIP</h5>
        <form id="importForm" class="row g-2 align-items-center">
            <div class="col-auto">
                <input type="file" id="zipFile" name="zipFile" accept=".zip" class="form-control" required />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">Import</button>
            </div>
        </form>
        <p class="text-muted small mt-2 mb-0">Duplicate cleanup, posters, and genres are fetched automatically after import.</p>
    </div>
</div>

<div id="section-watching"></div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Currently Watching <span class="badge bg-secondary">@Model.CurrentlyWatching.Count</span></h4>
</div>

<div class="library-scroll-row mb-5 library-section" id="currentlyWatchingGrid" data-empty-text="No matches in Currently Watching">
    @if (!Model.CurrentlyWatching.Any())
    {
        <div class="no-results-placeholder">
            <p class="text-muted">Nothing in progress — shows with some watched and some unwatched episodes will show up here.</p>
        </div>
    }

    @foreach (var show in Model.CurrentlyWatching)
    {
        var watchedCount = show.Episodes.Count(e => e.Watched);
        var totalCount = show.Episodes.Count;
        var percent = totalCount > 0 ? (int)((double)watchedCount / totalCount * 100) : 0;

        <div class="library-scroll-item library-card" data-title="@show.Title.ToLower()">
            <div class="card h-100 shadow-sm">
                <a asp-controller="Show" asp-action="Details" asp-route-id="@show.Id">
                    <img src="@(show.PosterImage != null ? Url.Action("Show", "Poster", new { id = show.Id }) : "/images/placeholder.png")"
                         class="card-img-top library-poster"
                         alt="@show.Title" />
                </a>
                <div class="card-body p-2">
                    <p class="card-text small fw-semibold mb-1">@show.Title</p>
                    @if (!string.IsNullOrEmpty(show.Genre))
                    {
                        <span class="badge bg-light text-dark border mb-1">@show.Genre.Split(',')[0]</span>
                    }
                    <div class="progress mb-1 library-progress-sm">
                        <div class="progress-bar bg-primary" style="width:@percent%"></div>
                    </div>
                    <span class="text-muted small">@watchedCount / @totalCount episodes</span>
                </div>
            </div>
        </div>
    }
</div>

<div id="section-shows"></div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Shows <span class="badge bg-secondary">@Model.Shows.Count</span></h4>
    <div>
        <a asp-controller="Library" asp-action="AllShows" class="btn btn-outline-dark btn-sm">View All Shows</a>
    </div>
</div>

<div class="library-scroll-row mb-5 library-section" id="showsGrid" data-empty-text="No matching shows">
    @foreach (var show in Model.Shows)
    {
        var showWatchedCount = show.Episodes.Count(e => e.Watched);
        var showTotalCount = show.Episodes.Count;
        var showFullyWatched = showTotalCount > 0 && showWatchedCount == showTotalCount;

        <div class="library-scroll-item show-card library-card" data-title="@show.Title.ToLower()">
            <div class="card h-100 shadow-sm">
                <a asp-controller="Show" asp-action="Details" asp-route-id="@show.Id">
                    <img src="@(show.PosterImage != null ? Url.Action("Show", "Poster", new { id = show.Id }) : "/images/placeholder.png")"
                         class="card-img-top library-poster"
                         alt="@show.Title" />
                </a>
                <div class="card-body p-2">
                    <p class="card-text small fw-semibold mb-1">@show.Title</p>
                    @if (!string.IsNullOrEmpty(show.Genre))
                    {
                        <span class="badge bg-light text-dark border">@show.Genre.Split(',')[0]</span>
                    }
                    @if (show.Archived)
                    {
                        <span class="badge bg-secondary">Archived</span>
                    }
                </div>
                <div class="card-footer p-2 bg-white border-0 d-flex flex-column gap-1">
                    @if (!showFullyWatched)
                    {
                        <form asp-controller="Show" asp-action="MarkAllWatched" method="post"
                              data-confirm="Mark all released episodes of @show.Title as watched?">
                            <input type="hidden" name="showId" value="@show.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <button type="submit" class="btn btn-outline-success btn-sm w-100">✓ Mark Watched</button>
                        </form>
                    }
                    <form asp-controller="Library" asp-action="DeleteShow" asp-route-id="@show.Id" method="post" data-confirm="Remove this show?">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">✕ Remove</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<div id="section-movies"></div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Movies <span class="badge bg-secondary">@Model.Movies.Count</span></h4>
    <a asp-controller="Library" asp-action="AllMovies" class="btn btn-outline-dark btn-sm">View All Movies</a>
</div>

<div class="library-scroll-row mb-5 library-section" id="moviesGrid" data-empty-text="No matching movies">
    @foreach (var movie in Model.Movies)
    {
        <div class="library-scroll-item movie-card library-card" data-title="@movie.Title.ToLower()">
            <div class="card h-100 shadow-sm">
                <a asp-controller="Movie" asp-action="Details" asp-route-id="@movie.Id">
                    <img src="@(movie.PosterImage != null ? Url.Action("Movie", "Poster", new { id = movie.Id }) : "/images/placeholder.png")"
                         class="card-img-top library-poster"
                         alt="@movie.Title" />
                </a>
                <div class="card-body p-2">
                    <p class="card-text small fw-semibold mb-1">@movie.Title</p>
                    @if (!string.IsNullOrEmpty(movie.Genre))
                    {
                        <span class="badge bg-light text-dark border">@movie.Genre.Split(',')[0]</span>
                    }
                    @if (movie.WatchedAt != null)
                    {
                        <span class="text-muted small">Watched @movie.WatchedAt.Value.ToShortDateString()</span>
                    }
                </div>
                <div class="card-footer p-2 bg-white border-0 d-flex gap-1">
                    <form asp-controller="Movie" asp-action="ToggleWatched" method="post" class="flex-grow-1">
                        <input type="hidden" name="movieId" value="@movie.Id" />
                        <button type="submit" class="btn btn-sm w-100 @(movie.Watched ? "btn-success" : "btn-outline-secondary")">
                            @(movie.Watched ? "✓ Watched" : "Mark Watched")
                        </button>
                    </form>
                    <form asp-controller="Library" asp-action="DeleteMovie" asp-route-id="@movie.Id" method="post" data-confirm="Remove this movie?">
                        <button type="submit" class="btn btn-outline-danger btn-sm">✕</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<div id="section-manga"></div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>My Manga, Manhwa & Manhua <span class="badge bg-secondary">@Model.MangaList.Count</span></h4>
    <div>
        <a asp-controller="Library" asp-action="AllManga" class="btn btn-outline-dark btn-sm">View All Manga</a>
    </div>
</div>

<div class="library-scroll-row mb-5 library-section" id="mangaGrid" data-empty-text="No matching manga titles">
    @if (!Model.MangaList.Any())
    {
        <div class="no-results-placeholder">
            <p class="text-muted">No manga, manhwa, or manhua added yet — browse and add titles from the Manga page.</p>
        </div>
    }

    @foreach (var manga in Model.MangaList)
    {
        var readCount = manga.ChaptersRead;
        var totalCount = manga.TotalChapters;
        var percent = totalCount.HasValue && totalCount.Value > 0
            ? (int)((double)readCount / totalCount.Value * 100)
            : 0;

        <div class="library-scroll-item manga-card library-card" data-title="@manga.Title.ToLower()">
            <div class="card h-100 shadow-sm">
                <a asp-controller="Manga" asp-action="Details" asp-route-id="@manga.Id">
                    <img src="@(manga.CoverImage != null ? Url.Action("Cover", "Manga", new { id = manga.Id }) : (manga.CoverUrl ?? "/images/placeholder.png"))"
                         class="card-img-top library-manga-cover"
                         alt="@manga.Title" />
                </a>
                <div class="card-body p-2">
                    <p class="card-text small fw-semibold mb-1">@manga.Title</p>
                    <span class="badge bg-info text-dark mb-1">@manga.Format</span>
                    @if (!string.IsNullOrEmpty(manga.Genre))
                    {
                        <span class="badge bg-light text-dark border mb-1">@manga.Genre.Split(',')[0]</span>
                    }
                    @if (manga.Completed)
                    {
                        <span class="badge bg-success">✓ Completed</span>
                    }
                    else if (totalCount.HasValue)
                    {
                        <div class="progress mb-1 library-progress-sm">
                            <div class="progress-bar bg-primary" style="width:@percent%"></div>
                        </div>
                        <span class="text-muted small">Ch. @readCount / @totalCount</span>
                    }
                    else
                    {
                        <span class="text-muted small">Ch. @readCount read</span>
                    }
                </div>
                <div class="card-footer p-2 bg-white border-0">
                    <form asp-controller="Manga" asp-action="Delete" asp-route-id="@manga.Id" method="post" data-confirm="Remove this title?">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">✕ Remove</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

<div id="section-games"></div>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>My Games <span class="badge bg-secondary">@Model.GamesList.Count</span></h4>
    <div>
        <a asp-controller="Library" asp-action="AllGames" class="btn btn-outline-dark btn-sm">View All Games</a>
    </div>
</div>

<div class="library-scroll-row mb-5 library-section" id="gamesGrid" data-empty-text="No matching games">
    @if (!Model.GamesList.Any())
    {
        <div class="no-results-placeholder">
            <p class="text-muted">No games added yet — browse and add titles from the Games page.</p>
        </div>
    }

    @foreach (var game in Model.GamesList)
    {
        <div class="library-scroll-item game-card library-card" data-title="@game.Title.ToLower()">
            <div class="card h-100 shadow-sm">
                <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id">
                    <img src="@(game.CoverImage != null ? Url.Action("Cover", "Games", new { id = game.Id }) : (game.CoverUrl ?? "/images/placeholder.png"))"
                         class="card-img-top library-poster"
                         alt="@game.Title" />
                </a>
                <div class="card-body p-2">
                    <p class="card-text small fw-semibold mb-1">@game.Title</p>
                    @if (!string.IsNullOrEmpty(game.Genre))
                    {
                        <span class="badge bg-light text-dark border mb-1">@game.Genre.Split(',')[0]</span>
                    }
                    @if (game.Completed)
                    {
                        <span class="badge bg-success">✓ Completed</span>
                    }
                    else if (game.Playing)
                    {
                        <span class="badge bg-primary">▶ Playing</span>
                    }
                    <div><span class="text-muted small">@game.HoursPlayed.ToString("0.#") hrs</span></div>
                </div>
                <div class="card-footer p-2 bg-white border-0 d-flex flex-column gap-1">
                    <form asp-controller="Games" asp-action="TogglePlaying" asp-route-id="@game.Id" method="post">
                        <button type="submit" class="btn btn-sm w-100 @(game.Playing ? "btn-primary" : "btn-outline-secondary")">
                            @(game.Playing ? "▶ Playing" : "Set Playing")
                        </button>
                    </form>
                    <form asp-controller="Games" asp-action="Delete" asp-route-id="@game.Id" method="post" data-confirm="Remove this game?">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">✕ Remove</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/Assets/JavaScript/library.js"></script>
}