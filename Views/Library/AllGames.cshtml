@model List<TvTimeViewer.Models.Game>
@{
    ViewData["Title"] = "All Games";
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/Style/all-games.css" />
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>All Games</h2>
    <div>
        <a asp-controller="Games" asp-action="Search" class="btn btn-outline-primary btn-sm me-2">🔍 Explore</a>
        <a asp-controller="Library" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back to Dashboard</a>
    </div>
</div>

<div class="row g-2 mb-4">
    <div class="col-auto flex-grow-1">
        <input type="text" id="allGamesSearch" class="form-control" placeholder="Search your games..." autocomplete="off" />
    </div>
</div>

<div class="row g-3" id="allGamesGrid">
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted mt-5">
            <h5>No games yet</h5>
            <p>Browse and add titles from the Games page.</p>
        </div>
    }

    @foreach (var game in Model)
    {
        <div class="col-6 col-md-3 col-lg-2 game-card" data-title="@game.Title.ToLower()">
            <div class="card h-100 shadow-sm">
                <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id">
                    <img src="@(game.CoverImage != null ? Url.Action("Cover", "Games", new { id = game.Id }) : (game.CoverUrl ?? "/images/placeholder.png"))"
                         class="card-img-top all-games-cover"
                         alt="@game.Title" />
                </a>

                <div class="card-body p-2">
                    <p class="card-text small fw-semibold mb-1">@game.Title</p>

                    @if (!string.IsNullOrEmpty(game.Genre))
                    {
                        <span class="badge bg-light text-dark border mb-1">@game.Genre.Split(',')[0]</span>
                    }

                    @if (game.Completed)
                    {
                        <span class="badge bg-success">✓ Completed</span>
                    }
                    else if (game.Playing)
                    {
                        <span class="badge bg-primary">▶ Playing</span>
                    }

                    <div>
                        <span class="text-muted small">@game.HoursPlayed.ToString("0.#") hrs</span>
                    </div>
                </div>

                <div class="card-footer p-2 bg-white border-0 d-flex flex-column gap-1">
                    <form asp-controller="Games" asp-action="TogglePlaying" asp-route-id="@game.Id" method="post">
                        <button type="submit" class="btn btn-sm w-100 @(game.Playing ? "btn-primary" : "btn-outline-secondary")">
                            @(game.Playing ? "▶ Playing" : "Set Playing")
                        </button>
                    </form>

                    <form asp-controller="Games" asp-action="Delete" asp-route-id="@game.Id" method="post" data-confirm="Remove this game?">
                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">✕ Remove</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/Assets/JavaScript/all-games.js"></script>
}