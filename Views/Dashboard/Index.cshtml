@model TvTimeViewer.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    int episodePct = Model.TotalEpisodes > 0 ? Model.WatchedEpisodes * 100 / Model.TotalEpisodes : 0;
    int moviePct = Model.TotalMovies > 0 ? Model.WatchedMovies * 100 / Model.TotalMovies : 0;
    int posterPct = (Model.TotalShows + Model.TotalMovies) > 0
        ? 100 - ((Model.MissingShowPosters + Model.MissingMoviePosters) * 100 / (Model.TotalShows + Model.TotalMovies))
        : 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Dashboard</h2>
    <a asp-controller="Library" asp-action="Index" class="btn btn-outline-secondary btn-sm">Go to Library</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Shows</h6>
                <h3>@Model.TotalShows</h3>
                <span class="badge bg-success">@Model.FollowedShows following</span>
                @if (Model.ArchivedShows > 0)
                {
                    <span class="badge bg-secondary">@Model.ArchivedShows archived</span>
                }
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Movies</h6>
                <h3>@Model.TotalMovies</h3>
                <span class="badge bg-success">@Model.WatchedMovies watched</span>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Episodes</h6>
                <h3>@Model.WatchedEpisodes<span class="text-muted fs-6">/@Model.TotalEpisodes</span></h3>
                <span class="badge bg-info text-dark">@episodePct% complete</span>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted">Posters Fetched</h6>
                <h3>@posterPct%</h3>
                @if (Model.MissingShowPosters + Model.MissingMoviePosters > 0)
                {
                    <form asp-controller="Library" asp-action="RefreshPosters" method="post">
                        <button type="submit" class="btn btn-outline-info btn-sm mt-1">Fetch Missing</button>
                    </form>
                }
                else
                {
                    <span class="badge bg-success">All posters loaded</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <label class="small text-muted">Episode watch progress</label>
        <div class="progress mb-3" style="height:10px;">
            <div class="progress-bar bg-success" style="width:@episodePct%"></div>
        </div>
    </div>
    <div class="col-md-6">
        <label class="small text-muted">Movie watch progress</label>
        <div class="progress mb-3" style="height:10px;">
            <div class="progress-bar bg-primary" style="width:@moviePct%"></div>
        </div>
    </div>
</div>

@if (Model.TopUnwatchedShows.Any())
{
    <h4 class="mb-3">Continue Watching</h4>
    <div class="row g-3 mb-5">
        @foreach (var show in Model.TopUnwatchedShows)
        {
            var unwatched = show.Episodes.Count(e => !e.Watched);
            <div class="col-6 col-md-4 col-lg-2">
                <a asp-controller="Show" asp-action="Details" asp-route-id="@show.Id" class="text-decoration-none text-dark">
                    <div class="card h-100 shadow-sm">
                        <img src="@(show.PosterImage != null ? Url.Action("Show", "Poster", new { id = show.Id }) : "/images/placeholder.png")"
                             class="card-img-top" alt="@show.Title" style="height:200px; object-fit:cover;" />
                        <div class="card-body p-2">
                            <p class="card-text small fw-semibold mb-1">@show.Title</p>
                            <span class="badge bg-warning text-dark">@unwatched left</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
}

<div class="row">
    <div class="col-md-6">
        <h5 class="mb-3">Recently Watched Shows</h5>
        @if (!Model.RecentlyWatchedShows.Any())
        {
            <p class="text-muted small">No episodes marked as watched yet.</p>
        }
        <ul class="list-group mb-4">
            @foreach (var show in Model.RecentlyWatchedShows)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a asp-controller="Show" asp-action="Details" asp-route-id="@show.Id" class="text-decoration-none">@show.Title</a>
                    <span class="text-muted small">@show.LastWatchedAt?.ToShortDateString()</span>
                </li>
            }
        </ul>
    </div>
    <div class="col-md-6">
        <h5 class="mb-3">Recently Watched Movies</h5>
        @if (!Model.RecentlyWatchedMovies.Any())
        {
            <p class="text-muted small">No movies marked as watched yet.</p>
        }
        <ul class="list-group mb-4">
            @foreach (var movie in Model.RecentlyWatchedMovies)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a asp-controller="Movie" asp-action="Details" asp-route-id="@movie.Id" class="text-decoration-none">@movie.Title</a>
                    <span class="text-muted small">@movie.WatchedAt?.ToShortDateString()</span>
                </li>
            }
        </ul>
    </div>
</div>