@model TvTimeViewer.Models.Manga
@{
    ViewData["Title"] = Model.Title;
    var readCount = Model.Chapters.Count(c => c.Read);
    var totalCount = Model.Chapters.Count;
    var percent = totalCount > 0 ? (int)((double)readCount / totalCount * 100) : 0;
    int? estDays = ViewBag.EstimatedDaysRemaining;
    DateTime? estDate = ViewBag.EstimatedNextDate;
    string estimateSource = ViewBag.EstimateSource ?? "none";
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/Style/manga-details.css" />
}

<div class="row mb-4">
    <div class="col-auto">
        <img src="@(Model.CoverImage != null ? Url.Action("Cover", "Manga", new { id = Model.Id }) : (Model.CoverUrl ?? "/images/placeholder.png"))"
             alt="@Model.Title"
             class="rounded shadow-sm manga-details-cover" />
    </div>

    <div class="col">
        <h2>@Model.Title</h2>
        <span class="badge bg-info text-dark mb-2">@Model.Format</span>

        @if (!string.IsNullOrEmpty(Model.Genre))
        {
            <p class="text-muted mb-2">@Model.Genre</p>
        }

        @if (Model.Completed)
        {
            <span class="badge bg-success mb-2">✓ Completed</span>
        }

        <div class="progress mb-2 manga-progress-wrap">
            <div class="progress-bar bg-primary" id="mangaProgressBar" style="width:@percent%">@percent%</div>
        </div>

        <p class="text-muted" id="mangaProgressText">@readCount / @totalCount chapters read</p>

        @if (!Model.Completed && estDays.HasValue)
        {
            string sourceLabel = estimateSource == "mangadex" ? "MangaDex release history" : "estimated pattern";
            <div class="next-chapter-badge">
                @if (estDays.Value > 0)
                {
                    <span>📅 Next chapter estimated in @estDays.Value day@(estDays.Value == 1 ? "" : "s") (~@estDate?.ToString("MMM dd")) · via @sourceLabel</span>
                }
                else
                {
                    <span>📅 Next chapter may already be out — check back soon · via @sourceLabel</span>
                }
            </div>
        }

        <div class="mt-2">
            <button type="button" id="btnAddChapter" class="btn btn-outline-primary btn-sm">+ Add Chapter</button>
        </div>
    </div>
</div>

<h4 class="mb-3">Chapters</h4>

@if (!Model.Chapters.Any())
{
    <p class="text-muted">No chapters tracked yet. Click "+ Add Chapter" to start tracking your reading progress.</p>
}

<div class="row g-2" id="chapterGrid">
    @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterNumber))
    {
        <div class="col-4 col-md-2 col-lg-1">
            <button type="button"
                    class="btn btn-sm w-100 chapter-btn @(chapter.Read ? "btn-success" : "btn-outline-secondary")"
                    data-chapter-id="@chapter.Id"
                    data-chapter-number="@chapter.ChapterNumber">
                Ch. @chapter.ChapterNumber
            </button>
        </div>
    }

    @if (!Model.Completed && estDays.HasValue)
    {
        <div class="col-4 col-md-2 col-lg-1">
            <button type="button" class="btn btn-sm w-100 chapter-btn-upcoming" disabled title="Not released yet">
                Ch. @(totalCount + 1)
                <div class="upcoming-days">@(estDays.Value > 0 ? $"{estDays.Value}d" : "Soon")</div>
            </button>
        </div>
    }
</div>

@section Scripts {
    <script>
        window.mangaDetailsConfig = {
            mangaId: @Model.Id,
            totalChapters: @totalCount
        };
    </script>
    <script src="~/Assets/JavaScript/manga-details.js"></script>
}