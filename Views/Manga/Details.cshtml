@model TvTimeViewer.Models.Manga
@{
    ViewData["Title"] = Model.Title;
    var readCount = Model.Chapters.Count(c => c.Read);
    var totalCount = Model.Chapters.Count;
    var percent = totalCount > 0 ? (int)((double)readCount / totalCount * 100) : 0;
    int? estDays = ViewBag.EstimatedDaysRemaining;
    DateTime? estDate = ViewBag.EstimatedNextDate;
    string estimateSource = ViewBag.EstimateSource ?? "none";
}

<div class="row mb-4">
    <div class="col-auto">
        <img src="@(Model.CoverImage != null ? Url.Action("Cover", "Manga", new { id = Model.Id }) : (Model.CoverUrl ?? "/images/placeholder.png"))"
             alt="@Model.Title" style="width:200px; height:280px; object-fit:cover;" class="rounded shadow-sm" />
    </div>
    <div class="col">
        <h2>@Model.Title</h2>
        <span class="badge bg-info text-dark mb-2">@Model.Format</span>
        @if (!string.IsNullOrEmpty(Model.Genre))
        {
            <p class="text-muted mb-2">@Model.Genre</p>
        }
        @if (Model.Completed)
        {
            <span class="badge bg-success mb-2">✓ Completed</span>
        }

        <div class="progress mb-2" style="height:14px; max-width:400px;">
            <div class="progress-bar bg-primary" id="mangaProgressBar" style="width:@percent%">@percent%</div>
        </div>
        <p class="text-muted" id="mangaProgressText">@readCount / @totalCount chapters read</p>

        @if (!Model.Completed && estDays.HasValue)
        {
            string sourceLabel = estimateSource == "mangadex" ? "MangaDex release history" : "estimated pattern";
            <div class="next-chapter-badge">
                @if (estDays.Value > 0)
                {
                    <span>📅 Next chapter estimated in @estDays.Value day@(estDays.Value == 1 ? "" : "s") (~@estDate?.ToString("MMM dd")) · via @sourceLabel</span>
                }
                else
                {
                    <span>📅 Next chapter may already be out — check back soon · via @sourceLabel</span>
                }
            </div>
        }

        <div class="mt-2">
            <button type="button" id="btnAddChapter" class="btn btn-outline-primary btn-sm">+ Add Chapter</button>
        </div>
    </div>
</div>

<h4 class="mb-3">Chapters</h4>

@if (!Model.Chapters.Any())
{
    <p class="text-muted">No chapters tracked yet. Click "+ Add Chapter" to start tracking your reading progress.</p>
}

<div class="row g-2" id="chapterGrid">
    @foreach (var chapter in Model.Chapters.OrderBy(c => c.ChapterNumber))
    {
        <div class="col-4 col-md-2 col-lg-1">
            <button type="button"
                    class="btn btn-sm w-100 chapter-btn @(chapter.Read ? "btn-success" : "btn-outline-secondary")"
                    data-chapter-id="@chapter.Id"
                    data-chapter-number="@chapter.ChapterNumber">
                Ch. @chapter.ChapterNumber
            </button>
        </div>
    }

    @if (!Model.Completed && estDays.HasValue)
    {
        <div class="col-4 col-md-2 col-lg-1">
            <button type="button" class="btn btn-sm w-100 chapter-btn-upcoming" disabled title="Not released yet">
                Ch. @(totalCount + 1)
                <div class="upcoming-days">@(estDays.Value > 0 ? $"{estDays.Value}d" : "Soon")</div>
            </button>
        </div>
    }
</div>

<style>
    .next-chapter-badge {
        display: inline-block;
        background: #2a2210;
        color: #d4af37;
        border: 1px solid #d4af37;
        padding: 6px 14px;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-top: 4px;
    }

    .chapter-btn-upcoming {
        background: #2a2a2a !important;
        color: #666 !important;
        border: 1px dashed #555 !important;
        cursor: not-allowed !important;
        display: flex;
        flex-direction: column;
        align-items: center;
        line-height: 1.1;
        padding: 6px 4px;
    }

    .upcoming-days {
        font-size: 0.65rem;
        color: #888;
    }
</style>

@section Scripts {
    <script>
        const mangaId = @Model.Id;
        const totalChapters = @totalCount;

        function updateProgressDisplay(readCount, total) {
            const percent = total > 0 ? Math.round((readCount / total) * 100) : 0;
            document.getElementById('mangaProgressBar').style.width = percent + '%';
            document.getElementById('mangaProgressBar').textContent = percent + '%';
            document.getElementById('mangaProgressText').textContent = `${readCount} / ${total} chapters read`;
        }

        document.getElementById('chapterGrid').addEventListener('click', async function (e) {
            const btn = e.target.closest('.chapter-btn');
            if (!btn) return;

            const chapterId = btn.dataset.chapterId;
            btn.disabled = true;

            try {
                const res = await fetch(`/Manga/ToggleChapter?chapterId=${chapterId}`, { method: 'POST' });
                const data = await res.json();

                if (data.success) {
                    btn.classList.toggle('btn-success', data.read);
                    btn.classList.toggle('btn-outline-secondary', !data.read);

                    const readCount = document.querySelectorAll('.chapter-btn.btn-success').length;
                    updateProgressDisplay(readCount, totalChapters);
                }
            } finally {
                btn.disabled = false;
            }
        });

        document.getElementById('btnAddChapter').addEventListener('click', async function () {
            const btn = this;
            btn.disabled = true;

            try {
                const res = await fetch(`/Manga/AddChapter?mangaId=${mangaId}`, { method: 'POST' });
                const data = await res.json();

                if (data.success) {
                    const grid = document.getElementById('chapterGrid');
                    const col = document.createElement('div');
                    col.className = 'col-4 col-md-2 col-lg-1';
                    col.innerHTML = `
                        <button type="button" class="btn btn-sm w-100 chapter-btn btn-outline-secondary"
                                data-chapter-id="${data.chapterId}" data-chapter-number="${data.chapterNumber}">
                            Ch. ${data.chapterNumber}
                        </button>`;
                    const upcomingCard = grid.querySelector('.chapter-btn-upcoming');
                    if (upcomingCard) {
                        grid.insertBefore(col, upcomingCard.closest('.col-4'));
                    } else {
                        grid.appendChild(col);
                    }
                }
            } finally {
                btn.disabled = false;
            }
        });
    </script>
}