@{
    ViewData["Title"] = "Manga & Manhwa";
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/Style/manga-search.css" />
}

<h2 class="mb-4">Manga, Manhwa & Manhua</h2>

<div class="row g-2 mb-4">
    <div class="col-auto">
        <select id="formatFilter" class="form-select">
            <option value="manga" selected>Manga (Japan)</option>
            <option value="manhwa">Manhwa (Korea)</option>
            <option value="manhua">Manhua (China)</option>
        </select>
    </div>
    <div class="col-auto">
        <select id="genreFilter" class="form-select">
            <option value="">All Genres</option>
        </select>
    </div>
</div>

<div class="row g-3 mb-4" id="mangaGrid"></div>

<div class="text-center mb-5">
    <button type="button" id="loadMoreBtn" class="btn btn-outline-primary">Load More</button>
</div>

@section Scripts {
    <script src="~/Assets/JavaScript/manga-search.js"></script>
}