@model TvTimeViewer.Models.Game
@{
    ViewData["Title"] = Model.Title;
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/Style/game-details.css" />
}

<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-2">
    <div class="game-details-header">
        <img src="@(Model.CoverImage != null ? Url.Action("Cover", "Games", new { id = Model.Id }) : (Model.CoverUrl ?? "/images/placeholder.png"))"
             alt="@Model.Title"
             class="game-cover shadow-sm" />

        <div>
            <h2 class="mb-2">@Model.Title</h2>

            <div class="d-flex gap-2 mb-2 flex-wrap">
                @if (!string.IsNullOrEmpty(Model.Genre))
                {
                    <span class="badge bg-light text-dark border">@Model.Genre</span>
                }
                @if (!string.IsNullOrEmpty(Model.Platform))
                {
                    <span class="badge bg-secondary">@Model.Platform</span>
                }
                @if (Model.ReleaseYear.HasValue)
                {
                    <span class="badge bg-light text-dark border">@Model.ReleaseYear</span>
                }
                @if (Model.Rating.HasValue)
                {
                    <span class="badge bg-warning text-dark">★ @Model.Rating.Value.ToString("0.0")</span>
                }
            </div>

            <div class="d-flex gap-2 mb-3 flex-wrap">
                @if (Model.Completed)
                {
                    <span class="badge bg-success fs-6">✓ Completed</span>
                }
                else if (Model.Playing)
                {
                    <span class="badge bg-primary fs-6">▶ Playing</span>
                }
                else
                {
                    <span class="badge bg-secondary fs-6">Backlog</span>
                }
            </div>

            <p class="text-muted mb-1">
                <strong>@Model.HoursPlayed.ToString("0.#")</strong> hours played
            </p>

            @if (Model.LastPlayedAt.HasValue)
            {
                <p class="text-muted small mb-0">Last played @Model.LastPlayedAt.Value.ToShortDateString()</p>
            }
        </div>
    </div>

    <a asp-controller="Library" asp-action="Index" class="btn btn-outline-secondary btn-sm">← Back to Library</a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3">Update Progress</h5>

        <div class="row g-3 align-items-end">
            <div class="col-auto">
                <form asp-controller="Games" asp-action="TogglePlaying" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="btn @(Model.Playing ? "btn-primary" : "btn-outline-secondary")">
                        @(Model.Playing ? "▶ Currently Playing" : "Set as Playing")
                    </button>
                </form>
            </div>

            <div class="col-auto">
                <form asp-controller="Games" asp-action="ToggleCompleted" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <button type="submit" class="btn @(Model.Completed ? "btn-success" : "btn-outline-success")">
                        @(Model.Completed ? "✓ Completed" : "Mark Completed")
                    </button>
                </form>
            </div>

            <div class="col-auto">
                <form id="hoursForm" asp-controller="Games" asp-action="UpdateHours" method="post" class="d-flex gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                    <input type="number" step="0.1" min="0" name="hours" value="@Model.HoursPlayed" class="form-control game-hours-input" />
                    <button type="submit" class="btn btn-outline-primary">Save Hours</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="card border-danger">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h6 class="card-title mb-1 text-danger">Remove from Library</h6>
            <p class="text-muted small mb-0">This will permanently delete this title from your library.</p>
        </div>

        <form asp-controller="Games" asp-action="Delete" asp-route-id="@Model.Id" method="post" data-confirm="Remove @Model.Title from your library?">
            <button type="submit" class="btn btn-outline-danger">✕ Remove</button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/Assets/JavaScript/game-details.js"></script>
}