@model TvTimeViewer.Models.Show
@{
    ViewData["Title"] = Model.Title;

    var seasons = Model.Episodes
        .GroupBy(e => e.SeasonNumber)
        .OrderBy(g => g.Key)
        .ToList();

    var today = DateTime.UtcNow.Date;
    var watchedEpisodes = Model.Episodes.Count(e => e.Watched);
    var totalEpisodes = Model.Episodes.Count;
    var progressPercent = totalEpisodes > 0 ? watchedEpisodes * 100 / totalEpisodes : 0;
}

<div class="row mb-4">
    <div class="col-md-3">
        <img src="@(Model.PosterImage != null ? Url.Action("Show", "Poster", new { id = Model.Id }) : "/images/placeholder.png")"
             class="img-fluid rounded shadow-sm"
             alt="@Model.Title" />
    </div>

    <div class="col-md-9">
        <h2>@Model.Title</h2>

        <div class="mb-2">
            @if (Model.Archived)
            {
                <span class="badge bg-secondary">Archived</span>
            }

            @if (!string.IsNullOrEmpty(Model.Genre))
            {
                <span class="badge bg-light text-dark border">@Model.Genre</span>
            }
        </div>

        <p class="text-muted" id="showProgressText">
            @watchedEpisodes of @totalEpisodes episodes watched
        </p>

        <div class="progress mb-3" style="height:8px;">
            <div id="showProgressBar"
                 class="progress-bar bg-success"
                 style="width:@progressPercent%"></div>
        </div>
    </div>
</div>

<div class="episodes-panel">
    <div class="episodes-panel-header">
        <span>All episodes</span>

        <form asp-controller="Show"
              asp-action="MarkAllWatched"
              method="post"
              data-confirm="Mark all RELEASED episodes in this show as watched?"
              class="d-inline">
            <input type="hidden" name="showId" value="@Model.Id" />
            <button type="submit"
                    class="check-btn @(Model.Episodes.Any() && Model.Episodes.All(e => e.Watched) ? "check-btn-active" : "")"
                    title="Mark all released episodes watched">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path d="M5 13l4 4L19 7" />
                </svg>
            </button>
        </form>
    </div>

    @foreach (var season in seasons)
    {
        var episodes = season.OrderBy(e => e.EpisodeNumber).ToList();
        var watchedCount = episodes.Count(e => e.Watched);
        var totalCount = episodes.Count;
        var allWatched = watchedCount == totalCount;
        var label = season.Key == 0 ? "Specials" : $"Season {season.Key}";

        <div class="season-row" data-season-number="@season.Key">
            <div class="season-row-main"
                 data-bs-toggle="collapse"
                 data-bs-target="#season@(season.Key)Body"
                 aria-expanded="false">
                <span class="season-title">
                    @label
                    <svg class="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M6 9l6 6 6-6" />
                    </svg>
                </span>

                <div class="season-right">
                    <span class="season-count" id="seasonCount-@season.Key">@watchedCount/@totalCount</span>

                    <form asp-controller="Show"
                          asp-action="MarkSeasonWatched"
                          method="post"
                          data-confirm="Mark all RELEASED episodes of @label as watched?"
                          class="d-inline"
                          onclick="event.stopPropagation()">
                        <input type="hidden" name="showId" value="@Model.Id" />
                        <input type="hidden" name="seasonNumber" value="@season.Key" />
                        <button type="submit"
                                class="check-btn season-check-btn @(allWatched ? "check-btn-active" : "")"
                                data-season-button="@season.Key"
                                title="Mark season's released episodes watched">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <path d="M5 13l4 4L19 7" />
                            </svg>
                        </button>
                    </form>
                </div>
            </div>

            <div class="collapse" id="season@(season.Key)Body">
                <ul class="episode-list">
                    @foreach (var ep in episodes)
                    {
                        var isReleased = ep.AirDate.HasValue && ep.AirDate.Value.Date <= today;
                        var daysRemaining = ep.AirDate.HasValue ? (ep.AirDate.Value.Date - today).Days : (int?)null;

                        <li class="episode-row" data-episode-row data-season="@ep.SeasonNumber">
                            <span class="episode-name">
                                E@(ep.EpisodeNumber.ToString("00")) — @ep.Name

                                @if (!isReleased)
                                {
                                    if (ep.AirDate.HasValue && daysRemaining.HasValue && daysRemaining.Value > 0)
                                    {
                                        <span class="release-badge">Releases in @daysRemaining.Value day@(daysRemaining.Value == 1 ? "" : "s")</span>
                                    }
                                    else if (ep.AirDate.HasValue && daysRemaining == 0)
                                    {
                                        <span class="release-badge release-today">Releases today</span>
                                    }
                                    else
                                    {
                                        <span class="release-badge release-tba">Release date TBA</span>
                                    }
                                }
                            </span>

                            <button type="button"
                                    class="check-btn check-btn-sm episode-toggle-btn @(ep.Watched ? "check-btn-active" : "") @(!isReleased ? "check-btn-disabled" : "")"
                                    data-episode-id="@ep.Id"
                                    data-season-number="@ep.SeasonNumber"
                                    data-watched="@(ep.Watched.ToString().ToLower())"
                                    @(!isReleased ? "disabled title=\"Not released yet\"" : "title=\"Toggle watched\"")>
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                    <path d="M5 13l4 4L19 7" />
                                </svg>
                            </button>
                        </li>
                    }
                </ul>
            </div>
        </div>
    }
</div>

<a asp-controller="Library" asp-action="Index" class="btn btn-outline-secondary mt-4">← Back to Library</a>

<style>
    .episodes-panel {
        background: #0d0d0d;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 2rem;
    }

    .episodes-panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 20px;
        color: #fff;
        font-size: 1.1rem;
        font-weight: 700;
    }

    .season-row {
        border-top: 3px solid #d4af37;
    }

    .season-row-main {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 18px 20px;
        background: #111;
        cursor: pointer;
        user-select: none;
    }

    .season-row-main:hover {
        background: #1a1a1a;
    }

    .season-title {
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .chevron {
        color: #888;
        transition: transform 0.2s;
    }

    .season-row-main[aria-expanded="true"] .chevron {
        transform: rotate(180deg);
    }

    .season-right {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .season-count {
        color: #aaa;
        font-size: 0.95rem;
        min-width: 45px;
        text-align: right;
    }

    .check-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: none;
        background: #e8e8e8;
        color: #999;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .check-btn:hover {
        background: #d4d4d4;
    }

    .check-btn-active {
        background: #2ecc71;
        color: #fff;
    }

    .check-btn-sm {
        width: 28px;
        height: 28px;
    }

    .check-btn-disabled {
        background: #2a2a2a !important;
        color: #555 !important;
        cursor: not-allowed !important;
        opacity: 0.6;
    }

    .check-btn-disabled:hover {
        background: #2a2a2a !important;
    }

    .check-btn-loading {
        opacity: 0.7;
        pointer-events: none;
    }

    .episode-list {
        list-style: none;
        margin: 0;
        padding: 0;
        background: #0a0a0a;
    }

    .episode-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 20px 12px 40px;
        border-bottom: 1px solid #1c1c1c;
        gap: 12px;
    }

    .episode-name {
        color: #ccc;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .release-badge {
        font-size: 0.75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 12px;
        background: #2a2210;
        color: #d4af37;
        border: 1px solid #d4af37;
        white-space: nowrap;
    }

    .release-today {
        background: #123a1e;
        color: #2ecc71;
        border-color: #2ecc71;
    }

    .release-tba {
        background: #2a2a2a;
        color: #888;
        border-color: #555;
    }
</style>

@section Scripts {
    <script>
        document.addEventListener('click', async function (e) {
            const btn = e.target.closest('.episode-toggle-btn');
            if (!btn || btn.disabled) return;

            const episodeId = btn.dataset.episodeId;
            const seasonNumber = btn.dataset.seasonNumber;
            const wasWatched = btn.dataset.watched === 'true';

            btn.disabled = true;
            btn.classList.add('check-btn-loading');

            try {
                const formData = new FormData();
                formData.append('episodeId', episodeId);

                const res = await fetch('/Show/ToggleWatched', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!res.ok) {
                    throw new Error(`HTTP ${res.status}`);
                }

                const data = await res.json();

                if (!data.success) {
                    throw new Error(data.message || 'Could not update episode.');
                }

                const isWatched = !!data.watched;
                btn.dataset.watched = isWatched ? 'true' : 'false';
                btn.classList.toggle('check-btn-active', isWatched);

                updateSeasonCount(seasonNumber);
                updateShowProgress();
            } catch (err) {
                console.error('Episode toggle failed:', err);
                alert('Could not update this episode.');
                btn.dataset.watched = wasWatched ? 'true' : 'false';
                btn.classList.toggle('check-btn-active', wasWatched);
            } finally {
                btn.disabled = false;
                btn.classList.remove('check-btn-loading');
            }
        });

        function updateSeasonCount(seasonNumber) {
            const seasonButtons = document.querySelectorAll(`.episode-toggle-btn[data-season-number="${seasonNumber}"]`);
            const watchedCount = Array.from(seasonButtons).filter(b => b.dataset.watched === 'true').length;
            const totalCount = seasonButtons.length;

            const seasonCountEl = document.getElementById(`seasonCount-${seasonNumber}`);
            if (seasonCountEl) {
                seasonCountEl.textContent = `${watchedCount}/${totalCount}`;
            }

            const seasonBtn = document.querySelector(`[data-season-button="${seasonNumber}"]`);
            if (seasonBtn) {
                seasonBtn.classList.toggle('check-btn-active', totalCount > 0 && watchedCount === totalCount);
            }
        }

        function updateShowProgress() {
            const allEpisodeButtons = document.querySelectorAll('.episode-toggle-btn');
            const watchedCount = Array.from(allEpisodeButtons).filter(b => b.dataset.watched === 'true').length;
            const totalCount = allEpisodeButtons.length;
            const percent = totalCount > 0 ? Math.round((watchedCount * 100) / totalCount) : 0;

            const progressText = document.getElementById('showProgressText');
            const progressBar = document.getElementById('showProgressBar');

            if (progressText) {
                progressText.textContent = `${watchedCount} of ${totalCount} episodes watched`;
            }

            if (progressBar) {
                progressBar.style.width = `${percent}%`;
            }
        }
    </script>
}