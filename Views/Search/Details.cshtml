@model TvTimeViewer.Models.OmdbDetail
@{ ViewData["Title"] = Model.Title; }

@if (TempData["Message"] != null) { <div class="alert alert-success">@TempData["Message"]</div> }

<div class="row">
    <div class="col-md-3">
        <img src="@(Model.Poster != "N/A" ? Model.Poster : "/images/placeholder.png")" class="img-fluid rounded shadow-sm" alt="@Model.Title" />
    </div>
    <div class="col-md-9">
        <h2>@Model.Title <small class="text-muted">(@Model.Year)</small></h2>
        <div class="mb-3">
            <span class="badge bg-warning text-dark fs-6">⭐ @Model.imdbRating</span>
            <span class="text-muted ms-2">@Model.imdbVotes votes</span>
        </div>
        <dl class="row">
            <dt class="col-sm-2">Genre</dt><dd class="col-sm-10">@Model.Genre</dd>
            <dt class="col-sm-2">Director</dt><dd class="col-sm-10">@Model.Director</dd>
            <dt class="col-sm-2">Actors</dt><dd class="col-sm-10">@Model.Actors</dd>
            <dt class="col-sm-2">Runtime</dt><dd class="col-sm-10">@Model.Runtime</dd>
        </dl>
        <p>@Model.Plot</p>
        <form asp-controller="Search" asp-action="AddToLibrary" method="post" class="mt-3">
            <input type="hidden" name="imdbId" value="@Model.imdbID" />
            <input type="hidden" name="title" value="@Model.Title" />
            <input type="hidden" name="poster" value="@Model.Poster" />
            <input type="hidden" name="type" value="@Model.Type" />
            <button type="submit" class="btn btn-primary">+ Add to My Library</button>
        </form>
    </div>
</div>

<a asp-controller="Search" asp-action="Index" class="btn btn-outline-secondary mt-4">← Back to Search</a>