@model List<TvTimeViewer.Models.OmdbSearchItem>
@{
    ViewData["Title"] = "Search";
}

@section Styles {
    <link rel="stylesheet" href="~/Assets/Style/search.css" />
}

<h2 class="mb-4">Search Shows and Movies</h2>

<form id="liveSearchForm" class="row g-2 mb-3" onsubmit="return false;">
    <div class="col-auto flex-grow-1 position-relative">
        <input type="text"
               id="liveSearchInput"
               value="@ViewBag.Query"
               class="form-control"
               placeholder="Search by title..."
               autocomplete="off" />
        <span id="liveSearchSpinner"
              class="spinner-border spinner-border-sm text-primary position-absolute search-spinner"></span>
    </div>
    <div class="col-auto">
        <button type="submit" id="searchSubmitBtn" class="btn btn-primary">Search</button>
    </div>
</form>

<div class="row g-2 mb-4" id="filterBar">
    <div class="col-auto">
        <select id="typeFilter" class="form-select">
            <option value="tv" selected>Shows</option>
            <option value="movie">Movies</option>
        </select>
    </div>
    <div class="col-auto">
        <select id="genreFilter" class="form-select">
            <option value="0">All Genres</option>
        </select>
    </div>
</div>

<div id="searchResultsContainer">
    @if (Model.Count == 0 && !string.IsNullOrEmpty(ViewBag.Query))
    {
        <div class="text-center text-muted mt-5">
            <h5>We're sorry!</h5>
            <p>We couldn't find any matches for "@ViewBag.Query"</p>
        </div>
    }
</div>

<div class="d-flex justify-content-between align-items-center mb-3" id="browseHeading">
    <h4>Browse Shows <span class="badge bg-secondary">Live from TMDb</span></h4>
</div>

<div class="row g-3" id="discoverGrid"></div>

<div class="text-center my-4">
    <button type="button" id="loadMoreBtn" class="btn btn-outline-primary">Load More</button>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Top Rated Shows <span class="badge bg-secondary">Live from TMDb</span></h4>
</div>
<div class="trending-scroll mb-5" id="topRatedShowsRow">
    <div class="trending-placeholder">Loading top rated shows...</div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Top Rated Movies <span class="badge bg-secondary">Live from TMDb</span></h4>
</div>
<div class="trending-scroll mb-5" id="topRatedMoviesRow">
    <div class="trending-placeholder">Loading top rated movies...</div>
</div>

@section Scripts {
    <script src="~/Assets/JavaScript/search.js"></script>
}